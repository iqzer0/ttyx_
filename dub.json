{
    "name": "ttyx",
    "description": "A tiling terminal emulator for Linux, forked from Tilix",
    "copyright": "Copyright © 2026, gwelr",
    "authors": ["gwelr", "Gerald Nunn and the Tilix contributors"],
    "mainSourceFile": "source/app.d",
    "dflags-ldc": ["-disable-linker-strip-dead","-link-defaultlib-shared=false"],
    "dependencies": {
        "gid:gtk3": "0.9.13",
        "gid:vte2": "0.9.13",
        "gid:pangocairo1": "0.9.13",
        "gid:secret1": "0.9.13"
    },
    "buildTypes": {
        "release": {
            "dflags": ["-release", "-inline", "-boundscheck=off"],
            "dflags-dmd": ["-O"],
            "dflags-ldc": ["-O3"]
        },
        "debug": {
            "debugVersions": ["GC"],
            "dflags": ["-g"]
        },
        "localize": {
            "versions": ["Localize"]
        },
        "i686": {
            "dflags": ["-m32", "-c"]
        }
    },

    "configurations": [
        {
            "name": "default",
            "targetType": "executable",
            "libs-linux": ["X11", "gdk-3"],
            "versions": ["StdLoggerDisableTrace"]
        },
        {
            "name": "trace",
            "targetType": "executable",
            "libs-linux": ["X11", "gdk-3"],
            "debugVersions": ["Destructors"]
        }
    ]
}
